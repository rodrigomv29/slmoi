# OpenAI API Key
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# LLaMA API Key (if using LLaMA)
LLAMA_KEY=<YOUR_LLAMA_API_KEY>

# News API Key
# Get your free API key from: https://newsapi.org/register
NEWS_API=<YOUR_NEWS_API_KEY>

# OpenWeather API Key
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=<YOUR_OPENWEATHER_API_KEY>

# Flask Secret Key
# Generate a random secret key for session management
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<YOUR_RANDOM_SECRET_KEY>

# Admin Credentials
ADMIN_USER=<YOUR_ADMIN_USERNAME>
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>

# AWS S3 Credentials (for Heroku Bucketeer add-on or your own S3)
# If using Heroku Bucketeer, these are auto-populated by the add-on
BUCKETEER_AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
BUCKETEER_AWS_REGION=<YOUR_AWS_REGION>
BUCKETEER_AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
BUCKETEER_BUCKET_NAME=<YOUR_S3_BUCKET_NAME>

# Hostname (for local development detection)
HOSTNAME=<YOUR_LOCAL_HOSTNAME>

# PostgreSQL Database URL (for Heroku Postgres or your own database)
# Format: postgres://username:password@host:port/database
DATABASE_URL=<YOUR_DATABASE_URL>

# User Agent (for API requests)
USER_AGENT="LLMWrapperSLMOI/1.0 (your-email@example.com)"
